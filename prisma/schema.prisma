generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]
  events        Event[]
  people        Person[]
  reflections   Reflection[]
  goals         Goal[]
  tasks         Task[]
  checkIns      DailyCheckIn[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Event {
  id            String   @id @default(cuid())
  title         String
  description   String?
  startTime     DateTime
  endTime       DateTime
  category      String   @default("Personal")
  role          String   @default("Student")
  outlookId     String?  @unique
  location      String?
  isLed         Boolean  @default(false)
  attended      Boolean  @default(true)
  actualMinutes Int?
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  interactions  Interaction[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Person {
  id              String   @id @default(cuid())
  name            String
  category        String
  email           String?
  phone           String?
  dateMet         DateTime?
  notes           String?
  prayerRequests  String?
  goals           String?
  tags            String?
  followUpDate    DateTime?
  lastContactDate DateTime?
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  interactions    Interaction[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Interaction {
  id        String   @id @default(cuid())
  type      String
  notes     String?
  date      DateTime @default(now())
  personId  String
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  eventId   String?
  event     Event?   @relation(fields: [eventId], references: [id])
  createdAt DateTime @default(now())
}

model Goal {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String
  targetDate  DateTime?
  progress    Int      @default(0)
  status      String   @default("active")
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks       Task[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  priority    String    @default("medium")
  status      String    @default("todo")
  role        String    @default("Student")
  hours       Float?
  goalId      String?
  goal        Goal?     @relation(fields: [goalId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model DailyCheckIn {
  id        String   @id @default(cuid())
  date      DateTime
  energy    Int
  stress    Int
  mood      Int
  sleep     Float?
  notes     String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, date])
}

model Reflection {
  id        String   @id @default(cuid())
  type      String
  date      DateTime
  content   String
  mood      Int?
  energy    Int?
  gratitude String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
